# NutriRPG Backend — Environment Variables
# Copiar para .env e preencher com os valores reais

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nutrirpg
DB_USER=postgres
DB_PASS=your_password_here

# JWT — generate a strong random secret, e.g.: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN=7d
