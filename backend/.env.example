# NutriRPG Backend — Environment Variables
# Copiar para .env e preencher com os valores reais

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nutrirpg
DB_USER=postgres
DB_PASS=your_password_here

# JWT
JWT_SECRET=nutrirpg_super_secret_change_in_production
JWT_EXPIRES_IN=7d
